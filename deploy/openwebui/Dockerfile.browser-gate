# Browser-only runtime for the OpenWebUI gate scripts in this directory.
# This is mcr.microsoft.com/playwright:v1.58.0-noble pinned to the locally
# verified content digest.  The base supplies matching Chromium binaries; this
# layer supplies the Node.js package that the bind-mounted scripts require.
FROM mcr.microsoft.com/playwright@sha256:35c7d48b4ccaf3aca5018f5f1bf7f50c7da7d61d176c530741f4f2e9ca336c34

ENV NODE_PATH=/usr/lib/node_modules

RUN PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    npm install --global --omit=dev --no-audit --no-fund playwright@1.58.0
