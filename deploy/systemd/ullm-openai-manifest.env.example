# Manifest mode contains slot operations settings only. Model identity, paths,
# hashes, tokenizer details, and worker arguments come exclusively from this
# validated active manifest.
ULLM_SERVED_MODEL_MANIFEST=/etc/ullm/served-models/active.json

ULLM_API_KEY_FILE=/etc/ullm/openai-api-key
ULLM_GPU_LOCK_FILE=/run/ullm/r9700.lock
ULLM_BIND_HOST=172.20.0.1
ULLM_BIND_PORT=8000
ULLM_HIP_VISIBLE_DEVICES=1

# deploy/openwebui/configure.py consumes this slot setting as well.
ULLM_OPENAI_BASE_URL=http://172.20.0.1:8000/v1
