# Paths are validated before the worker is admitted as ready.
ULLM_WORKER_BINARY=/home/homelab1/coding-local/ultimateLLM/uLLM-project/target/release/ullm-sq8-worker
ULLM_PRODUCT_ROOT=/home/homelab1/datapool/ullm/product/qwen3-14b-fp8-sq8-v0.1
ULLM_TOKENIZER_DIR=/home/homelab1/datapool/ai_models/safetensors/Qwen/Qwen3-14B-FP8

# These values are also consumed by deploy/openwebui/configure.py. Keep the
# served model ID and context length identical between the gateway and UI.
ULLM_MODEL_ID=ullm-qwen3-14b-sq8
ULLM_MODEL_NAME=uLLM Qwen3 14B SQ8
ULLM_MODEL_CONTEXT_LENGTH=4096
ULLM_MODEL_DESCRIPTION=Qwen3 14B served locally by uLLM SQ8_0.
ULLM_OPENAI_BASE_URL=http://172.20.0.1:8000/v1

# The key itself belongs in this root-managed file, never in this environment file.
ULLM_API_KEY_FILE=/etc/ullm/openai-api-key
ULLM_GPU_LOCK_FILE=/run/ullm/r9700.lock

# The gateway rejects any bind address other than loopback or this fixed bridge gateway.
ULLM_BIND_HOST=172.20.0.1
ULLM_BIND_PORT=8000
